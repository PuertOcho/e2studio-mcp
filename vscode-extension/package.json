{
  "name": "e2mcp",
  "displayName": "E2 MCP — Build, Flash & Debug",
  "description": "Renesas RX development: virtual console, project selector, build/flash integration for E2 Lite / E1 / J-Link",
  "version": "0.1.0",
  "publisher": "PuertOcho",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/.cproject",
    "onDebugResolve:renesas-hardware",
    "onView:e2mcp.panel"
  ],
  "extensionDependencies": [
    "renesaselectronicscorporation.renesas-debug"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "e2mcp",
          "title": "E2 MCP",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "e2mcp": [
        {
          "type": "webview",
          "id": "e2mcp.panel",
          "name": "E2 MCP"
        }
      ]
    },
    "commands": [
      {
        "command": "e2mcp.selectProject",
        "title": "Select Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.selectDebugger",
        "title": "Select Debugger",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.selectLaunch",
        "title": "Select Launch File",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.build",
        "title": "Build Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.clean",
        "title": "Clean Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.rebuild",
        "title": "Rebuild Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.flash",
        "title": "Flash Firmware",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.openConsole",
        "title": "Open Virtual Console Output",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.stopDebug",
        "title": "Stop Debug Session",
        "category": "E2 MCP"
      }
    ],
    "configuration": {
      "title": "E2 MCP",
      "properties": {
        "e2mcp.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to e2studio-mcp.json configuration file"
        },
        "e2mcp.pythonPath": {
          "type": "string",
          "default": "py",
          "description": "Python executable (py, python3, python)"
        },
        "e2mcp.consolePollMs": {
          "type": "number",
          "default": 500,
          "description": "Virtual console polling interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0"
  }
}
