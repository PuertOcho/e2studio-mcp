{
  "name": "e2mcp",
  "displayName": "E2 MCP — Build, Flash & Debug",
  "description": "Renesas RX development: virtual console, project selector, build/flash integration for E2 Lite / E1 / J-Link",
  "version": "0.2.6",
  "publisher": "PuertOcho",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/PuertOcho/e2studio-mcp"
  },
  "homepage": "https://github.com/PuertOcho/e2studio-mcp#readme",
  "bugs": {
    "url": "https://github.com/PuertOcho/e2studio-mcp/issues"
  },
  "keywords": [
    "renesas",
    "rx",
    "e2studio",
    "embedded",
    "mcp",
    "flash",
    "debug",
    "ccrx",
    "e2-lite",
    "j-link"
  ],
  "icon": "resources/E2_MCP.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/.cproject",
    "onDebugResolve:renesas-hardware"
  ],
  "extensionDependencies": [
    "renesaselectronicscorporation.renesas-debug"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "e2mcp",
          "title": "E2 MCP",
          "icon": "resources/E2_MCP_bar.png"
        }
      ]
    },
    "views": {
      "e2mcp": [
        {
          "type": "webview",
          "id": "e2mcp.panel",
          "name": "E2 MCP"
        }
      ]
    },
    "commands": [
      {
        "command": "e2mcp.selectProject",
        "title": "Select Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.selectProjectsFolder",
        "title": "Select Projects Folder",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.selectDebugger",
        "title": "Select Debugger",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.selectLaunch",
        "title": "Select Launch File",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.build",
        "title": "Build Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.clean",
        "title": "Clean Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.rebuild",
        "title": "Rebuild Project",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.openConsole",
        "title": "Open Virtual Console Output",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.flash",
        "title": "Flash Firmware",
        "category": "E2 MCP"
      },
      {
        "command": "e2mcp.stopDebug",
        "title": "Stop Debug Session",
        "category": "E2 MCP"
      }
    ],
    "configuration": {
      "title": "E2 MCP",
      "properties": {
        "e2mcp.workspace": {
          "type": "string",
          "default": "",
          "description": "Root folder containing Renesas e2 Studio projects"
        },
        "e2mcp.projectsPath": {
          "type": "string",
          "default": "",
          "description": "Override the folder that contains the Renesas e2 Studio projects (defaults to workspace)"
        },
        "e2mcp.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Default project name for build/flash/debug"
        },
        "e2mcp.buildConfig": {
          "type": "string",
          "default": "HardwareDebug",
          "description": "Build configuration name (e.g. HardwareDebug)"
        },
        "e2mcp.e2studioPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to e2 Studio `eclipse` folder (e.g. `C:\\Renesas\\e2_studio\\eclipse`). Auto-detected if empty."
        },
        "e2mcp.ccrxPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to CCRX compiler `bin` folder (e.g. `C:\\Program Files (x86)\\Renesas\\RX\\3_7_0\\bin`). Auto-detected if empty."
        },
        "e2mcp.makePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to GNU Make folder bundled with e2 Studio. Auto-detected if empty."
        },
        "e2mcp.debugToolsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to Renesas `DebugComp/RX` folder containing `e2-server-gdb`. Auto-detected if empty."
        },
        "e2mcp.python3BinPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to Renesas embedded Python3 `bin` folder. Auto-detected if empty."
        },
        "e2mcp.buildMode": {
          "type": "string",
          "default": "make",
          "enum": ["make", "e2studioc"],
          "markdownDescription": "Build backend: `make` (GNU Make) or `e2studioc` (e2 Studio CLI)."
        },
        "e2mcp.buildJobs": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Parallel build jobs for GNU Make (`-j`). `0` = auto (number of CPU cores)."
        },
        "e2mcp.pythonPath": {
          "type": "string",
          "default": "py",
          "description": "Python executable (py, python3, python)"
        },
        "e2mcp.consolePollMs": {
          "type": "number",
          "default": 500,
          "description": "Virtual console polling interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --sourcemap",
    "compile:prod": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "bundle": "node scripts/bundle.js",
    "prepackage": "node scripts/bundle.js",
    "package": "npm run compile:prod && vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0"
  }
}
